generator client {
  provider      = "prisma-client-js"
  // Netlify Functions run on AWS Lambda (Amazon Linux 2023, OpenSSL 3.x).
  // Without this target Prisma Client has no matching engine at runtime and the
  // serverless function crashes with a generic "unknown error".
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model UserSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  isOnboarded Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IncomeSource {
  id            String   @id @default(cuid())
  userId        String
  label         String
  amountMonthly Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Bucket {
  id              String   @id @default(cuid())
  userId          String
  name            String
  color           String
  sortOrder       Int
  allocatedAmount Decimal  @db.Decimal(14, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses    Expense[]
  allocations BucketAllocation[]

  @@index([userId])
}

model BucketAllocation {
  id             String   @id @default(cuid())
  bucketId       String
  label          String
  amount         Decimal  @db.Decimal(14, 2)
  platform       String
  allocationType String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bucket Bucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)

  @@index([bucketId])
}

model Expense {
  id         String   @id @default(cuid())
  userId     String
  bucketId   String?
  amount     Decimal  @db.Decimal(14, 2)
  category   String
  label      String?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  bucket       Bucket?       @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  groceryItems GroceryItem[]

  @@index([userId, occurredAt])
}

model Investment {
  id                String           @id @default(cuid())
  userId            String
  type              String
  label             String
  amount            Decimal          @db.Decimal(14, 2)
  expectedProfit    Decimal?         @db.Decimal(14, 2)
  actualProfit      Decimal?         @db.Decimal(14, 2)
  profitConfirmed   Boolean          @default(false)
  profitConfirmedAt DateTime?
  investedAt        DateTime
  maturityDate      DateTime?
  status            InvestmentStatus @default(ACTIVE)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([userId, maturityDate])
}

model RentJar {
  id          String   @id @default(cuid())
  userId      String   @unique
  annualRent  Decimal  @db.Decimal(14, 2)
  nextDueDate DateTime
  savedAmount Decimal  @default(0) @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GroceryItem {
  id                String    @id @default(cuid())
  userId            String
  listId            String?
  label             String
  quantity          String?
  estimatedPrice    Decimal?  @db.Decimal(14, 2)
  isPurchased       Boolean   @default(false)
  movedToExpenses   Boolean   @default(false)
  movedToExpensesAt DateTime?
  expenseId         String?
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  list    GroceryList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  expense Expense?     @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([userId, isPurchased, sortOrder])
  @@index([listId])
  @@index([expenseId])
}

model GroceryList {
  id              String   @id @default(cuid())
  userId          String
  name            String
  partiallyLogged Boolean  @default(false)
  isCompleted     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items GroceryItem[]

  @@index([userId])
}

enum JarCategory {
  RENT
  EMERGENCY_FUND
  GADGET
  TRAVEL
  EDUCATION
  INVESTMENT_CAPITAL
  BUSINESS
  CELEBRATION
  OTHER
}

model SavingsJar {
  id            String      @id @default(cuid())
  userId        String
  name          String
  emoji         String      @default("🏦")
  targetAmount  Decimal     @db.Decimal(14, 2)
  savedAmount   Decimal     @default(0) @db.Decimal(14, 2)
  monthlyTarget Decimal?    @db.Decimal(14, 2)
  dueDate       DateTime?
  color         String      @default("#16a34a")
  isCompleted   Boolean     @default(false)
  isPinned      Boolean     @default(false)
  category      JarCategory @default(OTHER)
  notes         String?
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  contributions JarContribution[]

  @@index([userId])
  @@index([userId, isPinned])
  @@index([userId, sortOrder])
}

model JarContribution {
  id        String   @id @default(cuid())
  jarId     String
  amount    Decimal  @db.Decimal(14, 2)
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  jar SavingsJar @relation(fields: [jarId], references: [id], onDelete: Cascade)

  @@index([jarId])
}

model MonthlySnapshot {
  id                String   @id @default(cuid())
  userId            String
  year              Int
  month             Int
  totalIncome       Decimal  @db.Decimal(14, 2)
  totalExpenses     Decimal  @db.Decimal(14, 2)
  totalSaved        Decimal  @db.Decimal(14, 2)
  savingsRate       Decimal  @db.Decimal(14, 6)
  expenseByCategory Json
  investmentValue   Decimal  @db.Decimal(14, 2)
  tbillsValue       Decimal  @db.Decimal(14, 2)
  risevest          Decimal  @db.Decimal(14, 2)
  piggyvest         Decimal  @db.Decimal(14, 2)
  ngx               Decimal  @db.Decimal(14, 2)
  jarsProgress      Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
}

model GroupSavingsJar {
  id           String    @id @default(cuid())
  createdById  String
  name         String
  emoji        String    @default("🏦")
  targetAmount Decimal   @db.Decimal(14, 2)
  dueDate      DateTime?
  color        String    @default("#16a34a")
  isCompleted  Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  members       GroupJarMember[]
  contributions GroupJarContribution[]

  @@index([createdById])
}

model GroupJarMember {
  id          String               @id @default(cuid())
  jarId       String
  userId      String?
  email       String
  displayName String?
  role        GroupJarRole         @default(MEMBER)
  status      GroupJarMemberStatus @default(PENDING)
  inviteToken String               @unique @default(cuid())
  invitedAt   DateTime             @default(now())
  joinedAt    DateTime?

  jar           GroupSavingsJar        @relation(fields: [jarId], references: [id], onDelete: Cascade)
  contributions GroupJarContribution[]

  @@index([jarId])
  @@index([userId])
  @@index([email])
}

model GroupJarContribution {
  id        String   @id @default(cuid())
  jarId     String
  memberId  String
  amount    Decimal  @db.Decimal(14, 2)
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  jar    GroupSavingsJar @relation(fields: [jarId], references: [id], onDelete: Cascade)
  member GroupJarMember  @relation(fields: [memberId], references: [id])

  @@index([jarId])
  @@index([memberId])
}

enum InvestmentStatus {
  ACTIVE
  MATURED
  MATURED_CONFIRMED
  ROLLED_OVER
  WITHDRAWN
}

enum GroupJarRole {
  ADMIN
  MEMBER
}

enum GroupJarMemberStatus {
  PENDING
  ACTIVE
  DECLINED
  REMOVED
}
