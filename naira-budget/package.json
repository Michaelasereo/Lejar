{
  "name": "naira-budget",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.example -e .env -e .env.local -- next dev",
    "build": "prisma generate && dotenv -e .env.example -e .env -e .env.local -- next build",
    "prisma:generate": "prisma generate",
    "prisma:push": "dotenv -e .env.example -e .env -e .env.local -- prisma db push",
    "prisma:migrate": "dotenv -e .env.example -e .env -e .env.local -- prisma migrate dev",
    "start": "dotenv -e .env.example -e .env -e .env.local -- next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:unit": "vitest run",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.57.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.65.0",
    "recharts": "^3.2.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "14.2.33",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
